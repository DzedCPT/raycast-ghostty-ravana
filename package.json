{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "agent-ghostty",
  "title": "Agent Ghostty",
  "description": "A Raycast extension for Ghostty",
  "icon": "extension-icon.png",
  "author": "jed",
  "license": "MIT",
  "commands": [
    {
      "name": "switch-agent",
      "title": "Switch Agent",
      "description": "List Claude Code sessions and jump to their Ghostty terminal",
      "mode": "view"
    },
    {
      "name": "index",
      "title": "Open Zed in Ghostty Dir",
      "description": "Open Zed in the working directory of the active Ghostty pane",
      "mode": "no-view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.2",
    "@raycast/utils": "^1.19.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.13.14",
    "@types/react": "19.0.12",
    "eslint": "^8.57.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "test": "vitest run"
  }
}
